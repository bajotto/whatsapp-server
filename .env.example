# WhatsApp service configuration
# Copy to .env and fill in your values

PORT=2061
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info
ENABLE_CONSOLE_LOGGING=true

# Required: master token for the /v2/apps admin API (register/list/delete apps)
# If unset, admin endpoints return 503.
WHATSAPP_ADMIN_TOKEN=change-me-to-a-strong-secret

# Path to the session bind mount directory on the host.
# The container mounts this at /app/.wwebjs_auth.
# Losing this directory means re-scanning the QR on every paired phone.
WHATSAPP_SESSION_DIR=/home/main/code/nice-agenda/whatsapp-session

# Optional: token for the legacy "nice-agenda" default app.
# If unset, a random token is generated on first boot and written to apps.json.
# DEFAULT_APP_TOKEN=

# Optional: webhook URL to receive events from the default app.
# WHATSAPP_DEFAULT_WEBHOOK_URL=

# Instance scaling (defaults shown)
# WHATSAPP_MAX_INSTANCES=50
# WHATSAPP_IDLE_EVICT_MS=1800000
# WHATSAPP_REAP_INTERVAL_MS=300000
